# ESP32-P4 target defaults derived from docs/research/esp-idf-skeleton-baseline.md.

# PSRAM is a baseline requirement for the planned capture and encode path.
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_HEX=y
CONFIG_SPIRAM_SPEED_200M=y

# Reserve the TinyUSB HID count baseline without enabling HID behavior yet.
CONFIG_TINYUSB_HID_COUNT=1
